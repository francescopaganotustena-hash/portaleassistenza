# Application
APP_NAME="Portale Assistenza Studio81"
APP_VERSION="1.0.0"
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./database.db
# Per produzione: postgresql+asyncpg://user:password@localhost:5432/portale_assistenza

# Security
SECRET_KEY=your-secret-key-here-change-in-production-use-secrets-manager
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 ore
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (opzionale - per produzione)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
MAIL_FROM_ADDR=your-email@gmail.com
MAIL_FROM_NAME="Portale Assistenza Studio81"

# Upload
MAX_FILE_SIZE=10485760  # 10MB
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080

# Rate Limiting
RATELIMIT_DEFAULT=100 per hour
RATELIMIT_STORAGE_URL=memory://
